# =========================================================================
# CV Maker - Unified Environment Configuration (Root .env.example)
# Use this file as a template for your .env file in the project root.
# =========================================================================

# -------------------------------------------------------------------------
# BACKEND CONFIGURATION
# -------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
JWT_SECRET=your_long_random_jwt_secret_here
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173

# Database (Used by server and Prisma)
# When running with Docker Compose, the host should be 'postgres' (as defined in services)
DATABASE_URL=postgresql://user:password@postgres:5432/cvmaker?schema=public

# Google OAuth (Backend)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Payment Gateway (Paymob)
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_INTEGRATION_ID=your_paymob_integration_id_here
PAYMOB_FRAME_ID=your_paymob_frame_id_here
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret_here

# AI Service (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@yourdomain.com
APP_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug

# -------------------------------------------------------------------------
# FRONTEND CONFIGURATION
# -------------------------------------------------------------------------
# Variables must be prefixed with VITE_ for the client to access them

VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_API_URL=http://localhost:4000