# ===========================================
# CV Maker Server Environment Configuration
# ===========================================

# Environment
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:5173

# ===========================================
# Database (Prisma Postgres)
# ===========================================
# Use the local connection string for development
# For Docker, use: postgresql://user:password@postgres:5432/cvmaker?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/cvmaker?schema=public"

# ===========================================
# Authentication
# ===========================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_client_id_here

# ===========================================
# Email (Resend)
# ===========================================
# Leave empty to log verification links to console (dev mode)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=your_verified_sender_email@domain.com
APP_URL=http://localhost:5173

# ===========================================
# Payments (Paymob)
# ===========================================
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_INTEGRATION_ID=your_paymob_integration_id_here
PAYMOB_FRAME_ID=your_paymob_frame_id_here
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret_here

# ===========================================
# AI / OpenRouter
# ===========================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug