generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  USER
  ADMIN
  RECRUITER
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String? // Hashed password (optional if only Google)
  googleId           String?   @unique
  avatar             String?
  role               Role      @default(USER)
  isEmailVerified    Boolean   @default(false)
  verificationToken  String?   @unique
  verificationExpiry DateTime?
  paymobOrderId      String?   @unique // For pending/completed order tracking
  stripeCustomerId   String?   @unique
  isPremium          Boolean   @default(false)
  resetToken         String?   @unique
  resetExpiry        DateTime?
  totpSecret         String?
  twoFactorEnabled       Boolean   @default(false)
  premiumExpiresAt       DateTime?
  resumes                Resume[]
  auditLogs              AuditLog[]
  notificationPreference NotificationPreference?
  jobApplications        JobApplication[]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Template {
  id           String   @id @default(uuid())
  name         String
  thumbnailUrl String?
  isPremium    Boolean  @default(false)
  config       Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   Json?
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
}


model Resume {
  id           String    @id @default(cuid())
  title        String    @default("Untitled Resume")
  content      Json
  isPublic     Boolean   @default(false)
  shareKey     String?   @unique
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  versions        ResumeVersion[]
  reviewSessions  ReviewSession[]
  jobApplications JobApplication[]

  @@index([userId])
}

model ResumeVersion {
  id        String   @id @default(cuid())
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  content   Json
  createdAt DateTime @default(now())

  @@index([resumeId])
}

model ReviewSession {
  id        String   @id @default(cuid())
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  token     String   @unique @default(cuid())
  expiresAt DateTime
  name      String?
  comments  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeId])
}

model NotificationPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeViewed         Boolean  @default(true)
  weeklyDigest         Boolean  @default(true)
  subscriptionReminder Boolean  @default(true)
  accountActivity      Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model NotificationLog {
  id     String   @id @default(uuid())
  userId String
  type   String
  sentAt DateTime @default(now())

  @@index([userId, type, sentAt])
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

model JobApplication {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId  String?
  resume    Resume?           @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  jobTitle  String
  company   String
  url       String?
  status    ApplicationStatus @default(SAVED)
  notes     String?
  salary    String?
  appliedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([userId, status])
}
